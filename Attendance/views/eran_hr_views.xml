<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_view_department_form_inherit" model="ir.ui.view">
        <field name="name">eran.view.department.form.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="code"/>
            </xpath>
        </field>
    </record>
    <record id="eran_view_employee_form" model="ir.ui.view">
        <field name="name">eran.view.employee.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='address_home_id']" position="before">
                <field name="signature"/>
            </xpath>
            <xpath expr="//field[@name='resource_calendar_id']" position="after">
                <field name="shift_id"/>
            </xpath>
        </field>
    </record>
</odoo>
