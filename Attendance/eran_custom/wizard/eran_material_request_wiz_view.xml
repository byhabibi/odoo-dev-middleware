<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_material_request_view" model="ir.ui.view">
        <field name="name">Material Request Additional</field>
        <field name="model">eran.material.request.wiz</field>
        <field name="arch" type="xml">
            <form string="Warning">

                <h1>
                    <field name="name" required="1" readonly="1"/>
                </h1>

                <group>
                    <group>
                        <field name="request_date"/>
                        <field name="requester_id"/>
                        <field name="production_id" invisible="1"/>
                        <field name="balance_check" invisible="1"/>
                    </group>
                    <group>
                        <field name="source_location_id"/>
                        <field name="reason"/>
                    </group>
                </group>
                <field name="material_request_line_ids">
                    <tree editable="bottom">
                        <field name="product_id"/>
                        <field name="product_qty" string="Quantity"/>
                        <field name="product_uom_id" />
                        <field name="quantity" string="Quantity" invisible="1"/>
                        <field name="uom_id" invisible="1"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" attrs="{'invisible': [('balance_check', '!=', True)]}" confirm="The quantity of material requested is more than the compenent material. Do you still want to continue?" class="oe_highlight"/>
                    <button name="action_confirm" string="Confirm" type="object" attrs="{'invisible': [('balance_check', '!=', False)]}" class="oe_highlight"/>
                    <button name="action_discard" string="Discard" type="object" />
                </footer>
            </form>
        </field>
    </record>

    <record id="eran_material_request_wiz_id" model="ir.actions.act_window">
        <field name="name">Material Request</field>
        <field name="res_model">eran.material.request.wiz</field>
        <field name="view_id" ref="eran_material_request_view"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>