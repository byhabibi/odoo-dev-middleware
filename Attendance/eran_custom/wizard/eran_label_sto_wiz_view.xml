<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="eran_label_sto_wiz_view" model="ir.ui.view">
        <field name="name">eran.label.sto.wiz.form</field>
        <field name="model">eran.label.sto.wiz</field>
        <field name="arch" type="xml">
            <form string="Label STO">
                <group>
                    <group name="left_sto_group">
                        <field name="product_id" widget="many2many_tags"/>
                        <field name="location_id" widget="many2many_tags"/>
                        <field name="product_category_id" widget="many2many_tags"/>
                    </group>
                    <group name="right_sto_group">
                        <field name="count_date" widget="date" format="dd/MM/yyyy"/>
                        <field name="counter_id"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_label_sto" string="Print" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="eran_label_sto_wiz_action" model="ir.actions.act_window">
        <field name="name">Label STO</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">eran.label.sto.wiz</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="eran_label_sto_wiz_view"/>
        <field name="target">new</field>
    </record>

    <!-- <menuitem
        action="eran_label_sto_wiz_action"
        id="eran_label_sto_wiz_menu"
        parent="stock.menu_warehouse_report" sequence="300"/> -->

</odoo>
