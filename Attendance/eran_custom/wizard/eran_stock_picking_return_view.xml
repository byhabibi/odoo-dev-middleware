<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="eran_view_stock_return_picking_form_inherit" model="ir.ui.view">
        <field name="name">eran.view.stock.return.picking.form.inherit</field>
        <field name="model">stock.return.picking</field>
        <field name="inherit_id" ref="stock.view_stock_return_picking_form" />
