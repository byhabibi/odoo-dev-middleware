<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_stock_picking_refund_view" model="ir.ui.view">
        <field name="name">eran.stock.picking.refund.view</field>
        <field name="model">eran.stock.picking.refund</field>
        <field name="arch" type="xml">
            <form string="Replacement Shipment">
                <sheet>
                    <field name="picking_id" invisible="1"/>
                    <div class="oe_grey">
                        <p>Are you sure you will send the item?</p>
                    </div>
                </sheet>
                <footer>
                    <button string="Yes" name="create_refund_product" type="object" class="oe_highlight" data-hotkey="s"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    
</odoo>