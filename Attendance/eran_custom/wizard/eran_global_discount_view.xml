<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_global_discount_view" model="ir.ui.view">
        <field name="name">eran.global.discount.wizard</field>
        <field name="model">eran.global.discount.wiz</field>
        <field name="arch" type="xml">
            <form string="Detail Discount">
                <sheet>
                    <group>
                        <field name="untaxed_amount" readonly="1"/>
                        <field name="discount_type" required="1"/>
                        <field name="fixed_amount" required="1" attrs="{'invisible': [('discount_type', '=', 'percentage')]}"/>
                        <field name="discount" string="Discount(%)" attrs="{'invisible': [('discount_type', '=', 'fixed')]}"/>
                        <field name="discount_amount" readonly="1" attrs="{'invisible': [('discount_type', '=', 'fixed')]}"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirm" name="btn_confirm" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>