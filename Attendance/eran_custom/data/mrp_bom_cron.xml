    <record id="ir_cron_sync_attendance_log" model="ir.cron">
        <field name="name">Attendance: Sync From Log Transaction</field>
        <field name="model_id" ref="model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_attendance_from_log()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
    </record>

    <record id="reminder_attendance_overtime_approval" model="mail.activity.type">
        <field name="name">Attendance Overtime Approval</field>
        <field name="icon">fa-users</field>
        <field name="sequence">3</field>
    </record>

