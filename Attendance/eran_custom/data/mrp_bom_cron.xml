<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_auto_reminder_bom" model="ir.cron">
        <field name="name">BOM: Show reminder if today is almost close to the end date of tooling</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=2, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')" />
        <field name="doall" eval="False"/>
        <field name="model_id" ref="model_mrp_bom"/>
        <field name="code">model.check_bom_end_date()</field>
        <field name="state">code</field>
    </record>

    <record id="ir_cron_quotation_expiration_notification" model="ir.cron">
        <field name="name">Quotation Expiration Notification</field>
        <field name="model_id" ref="model_eran_quotation"/>
        <field name="state">code</field>
        <field name="code">model.cron_remind_3_day_expire_notif()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=1, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')" />
        <field eval="False" name="doall"/>
    </record>

    <record id="ir_cron_update_expired_quotations" model="ir.cron">
        <field name="name">Update Expired Quotations</field>
        <field name="model_id" ref="model_eran_quotation"/>
        <field name="state">code</field>
        <field name="code">model.update_expired_quotations()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=1, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')" />
    </record>

    <record id="ir_cron_run_purchase_order_id" model="ir.cron">
        <field name="name">Update Purchase Order Picking</field>
        <field name="model_id" ref="model_stock_picking"/>
        <field name="state">code</field>
        <field name="code">model.run_purchase_order_id_all()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>

    <record id="ir_cron_master_date" model="ir.cron">
        <field name="name">Create Master Date</field>
        <field name="model_id" ref="model_master_date"/>
        <field name="state">code</field>
        <field name="code">model.cron_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>

