<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="eran_action_report_tag_sto" model="ir.actions.report">
        <field name="name">Tag STO</field>
        <field name="model">eran.tag.sto</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eran_custom.eran_tag_sto_report</field>
        <field name="report_file">eran_custom.eran_tag_sto_report</field>
        <field name="print_report_name">'Tag STO'</field>
        <field name="binding_model_id" ref="model_eran_tag_sto"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eran_paperformat_report_stock_opname"/>
    </record>

    <template id="eran_tag_sto_report">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <t t-set="no_tag" t-value="1"/>
                <div t-foreach="o.product_line_ids" t-as="line" class="page" style="font-size:14px; page-break-after:always;">
                    <div class="row" style="border-bottom:2px solid;">
                        <div class="col-12" style="text-align:center;">
                            <span style="font-size:16px;" t-field="o.company_id"/><br/>
                            <span>TAG STOCK OPNAME</span>
                        </div>
                    </div>
                    <br/>
                    <div class="row">
                        <div class="col-7">
                            <div class="row">
                                <div class="col-4">NO TAG</div>
                                <div class="col-1">:</div>
                                <div class="col-7"><span t-field="o.name"/></div>
                            </div>
                            <div class="row">
                                <div class="col-4">LOCATION</div>
                                <div class="col-1">:</div>
                                <div class="col-7"><span t-field="o.location_id"/></div>
                            </div>
                        </div>
                        <div class="col-5">
                            <div class="row">
                                <div class="col-6">PRINT DATE</div>
                                <div class="col-1">:</div>
                                <div class="col-5"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/></div>
                            </div>
                            <div class="row">
                                <div class="col-6">COUNT DATE</div>
                                <div class="col-1">:</div>
                                <div class="col-5"><t t-foreach="data_date_counter" t-as="var">
                                    <span t-esc="var" t-options="{&quot;widget&quot;: &quot;date&quot;,&quot;format&quot;: &quot;dd/MM/yyyy&quot;}"/>
                                </t></div>
                            </div>
                        </div>
                    </div><br/>
                    <div class="row">
                        <div class="col-12">
                            <table class="table table-bordered table-borderless">
                                <thead>
                                    <tr style="text-align:center;">
                                        <td style="border:1px solid; width:20%;">INTERNAL REFERENCE</td>
                                        <td style="border:1px solid; width:25%;">MATERIAL DESCRIPTION</td>
                                        <td style="border:1px solid; width:15%;">COUNTED QTY</td>
                                        <td style="border:1px solid; width:15%;">UOM</td>
                                        <td style="border:1px solid; width:25%;">NOTE</td>
                                    </tr>
                                </thead>
                                <tbody style="border-bottom:1px solid;">
                                    <tr>
                                        <td style="padding:1px; border-left:1px solid; border-right:1px solid; height:90px; width:20%; vertical-align:middle;">
                                            <span t-field="line.product_id.default_code"/><br/>
                                        </td>
                                        <td style="padding:1px; border-left:1px solid; border-right:1px solid; height:90px; width:25%; vertical-align:middle;">
                                            <span t-field="line.product_id.name"/><br/>
                                            <!-- <span t-field="o.lot_id"/> -->
                                        </td>
                                        <td style="padding:1px; border-right:1px solid; text-align:center; height:90px; width:15%; vertical-align:middle;">
                                            <!-- <t t-if="o.inventory_quantity!=0">
                                                <span t-field="o.inventory_quantity"/>
                                            </t> -->
                                        </td>
                                        <td style="padding:1px; border-right:1px solid; text-align:center; height:90px; width:15%; vertical-align:middle;">
                                            <span t-field="line.product_id.uom_id"/>
                                        </td>
                                        <td style="padding:1px; border-right:1px solid; height:90px; width:25%; vertical-align:middle;"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div><br/><br/>
                    <div class="row">
                        <div class="col-12">
                            <table class="table table-bordered table-borderless">
                                <tr>
                                    <td style="text-align:center; border:1px solid;" colspan="4">TANDA TANGAN</td>
                                </tr>
                                <tr>
                                    <td style="border:1px solid; height:65px; width:25%;"/>
                                    <td style="border:1px solid; height:65px; width:25%;"/>
                                    <td style="border:1px solid; height:65px; width:25%;"/>
                                    <td style="border:1px solid; height:65px; width:25%;"/>
                                </tr>
                                <tr style="text-align:center; font-size:12px;">
                                    <td style="padding:1px; border:1px solid; height:20px; width:25%;"><t t-foreach="data_counter" t-as="var">
                                        <span t-esc="var"/>
                                    </t></td>
                                    <td style="padding:1px; border:1px solid; height:20px; width:25%;"/>
                                    <td style="padding:1px; border:1px solid; height:20px; width:25%;"/>
                                    <td style="padding:1px; border:1px solid; height:20px; width:25%;"/>
                                </tr>
                                <tr style="text-align:center;">
                                    <td style="border:1px solid; width:25%;">COUNTER</td>
                                    <td style="border:1px solid; width:25%;">CHECKER</td>
                                    <td style="border:1px solid; width:25%;">DATA ENTRY</td>
                                    <td style="border:1px solid; width:25%;">INV CONTROL</td>
                                </tr>
                            </table>
                        </div>
                    </div><br/>
                    <div class="row">
                        <div class="col-8"><span font-size="11px">Inv. Control 2, Warehouse/PIC Area 3 Barang</span></div>
                    </div>
                    <t t-set="no_tag" t-value="no_tag+1"/>
                </div>
            </t>
        </t>
    </template>

</odoo>