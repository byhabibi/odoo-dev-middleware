<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- paperformat label of receipt -->
    <record id="eran_paperformat_report_label_of_receipt" model="report.paperformat">
        <field name="name">Label of Receipt Paperformat</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- paperformat label of receipt material-->
    <record id="eran_paperformat_report_label_of_receipt_material" model="report.paperformat">
        <field name="name">Label of Receipt Material Paperformat</field>
        <field name="default" eval="True"/>
        <field name="format">A6</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- action print label of receipt-->
    <record id="eran_action_report_label_of_receipt" model="ir.actions.report">
        <field name="name">Label of Receipt</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eran_custom.eran_label_of_receipt_report</field>
        <field name="report_file">eran_custom.eran_label_of_receipt_report</field>
        <field name="print_report_name">'Label of Receipt'</field>
        <field name="binding_model_id" ref="model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eran_paperformat_report_label_of_receipt"/>
    </record>

    <!-- action print label of receipt material-->
    <record id="eran_action_report_label_of_receipt_material" model="ir.actions.report">
        <field name="name">Label of Receipt Material</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eran_custom.eran_label_of_receipt_material_report</field>
        <field name="report_file">eran_custom.eran_label_of_receipt_material_report</field>
        <field name="print_report_name">'Label of Receipt Material'</field>
        <field name="binding_model_id" ref="model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eran_paperformat_report_label_of_receipt_material"/>
    </record>

    <!-- Label of Receipt Templates -->
    <template id="eran_label_of_receipt_report">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-size:14px;">
                    <t t-set="lot_list" t-value="[]"/>
                    <t t-foreach="o.move_line_ids_without_package" t-as="data">
                        <t t-set="lot_list" t-value="lot_list  + [data.lot_name]"/>
                    </t>

                    <t t-foreach="set(lot_list)" t-as="by_lot">
                        <t t-foreach="o.move_line_ids_without_package" t-as="line">
                            <t t-if="line.lot_name == by_lot">
                                <div class="row" style="width: 50%; float:left; padding:4px;">
                                    <div class="col-12">
                                        <div class="row">
                                            <div class="col-12" style="border: 2px solid;">
                                                <t t-if="o.company_id.logo">
                                                    <img t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 80px;max-width:300px;"/>
                                                </t>
                                            </div>
                                        </div>
                                        <div class="row" style="border-left: 2px solid; border-right: 2px solid; border-bottom: 2px solid;">
                                            <div class="col-12">
                                                <table class="table table-bordered table-borderless">
                                                    <tr>
                                                        <td style="border-right:2px solid; text-align:center; vertical-align:middle;" rowspan="14"><span t-if="line.product_id.barcode" t-field="line.product_id.barcode" t-options="{'widget': 'barcode','symbology':'QR', 'width': 115, 'height': 115, 'img_align': 'center'}"/></td>
                                                        <td style="padding:0px; padding-left:4px; padding-top:7px;" colspan="2">Part Name</td>
                                                    </tr>
                                                    <tr style="font-weight:bold; font-size:20px;">
                                                        <td style="padding:0px; padding-left:4px; height:23px;" colspan="2"><span t-field="line.product_id.name"/></td>
                                                    </tr>

                                                    <tr>
                                                        <td style="padding:0px; padding-left:4px; padding-top:5px;">Part Description</td>
                                                        <td style="padding:0px; padding-left:4px; padding-top:5px;">Lot Produksi</td>
                                                    </tr>
                                                    <tr style="font-weight:bold; font-size:16px;">
                                                        <td style="padding:0px; padding-left:4px; height:15px;"><span t-field="line.product_id.default_code"/></td>
                                                        <td style="padding:0px; padding-left:4px; height:15px;"><span t-field="line.lot_name"/></td>
                                                    </tr>

                                                    <tr>
                                                        <td style="padding:0px; padding-left:4px; padding-top:5px;" colspan="2">Customer</td>
                                                    </tr>
                                                    <tr>
                                                        <td style="padding:0px; padding-left:4px; height:15px;" colspan="2"><span t-field="o.partner_id"/></td>
                                                    </tr>

                                                    <tr>
                                                        <td style="padding:0px; padding-left:4px; padding-top:5px;">Tanggal</td>
                                                        <td style="padding:0px; padding-left:4px; padding-top:5px;">Jumlah</td>
                                                    </tr>
                                                    <tr>
                                                        <td style="padding:0px; padding-left:4px; height:15px;"><span t-field="o.date_done"/></td>
                                                        <td style="padding:0px; padding-left:4px; height:15px;"><span t-esc="int(line.qty_done)"/></td>
                                                    </tr>

                                                    <tr>
                                                        <td style="padding:0px; padding-left:4px; padding-top:5px; padding-bottom:7px;">Opr Check : </td>
                                                        <td style="padding:0px; padding-left:4px; padding-top:5px; padding-bottom:7px;">QC Check :</td>
                                                    </tr>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <!-- Label of Receipt Material Templates -->
    <template id="eran_label_of_receipt_material_report">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <t t-foreach="o.move_line_ids_without_package" t-as="line">
                    <div class="page" style="border:1px solid; font-size:14px; page-break-after:always;">
                        <!-- warehouse material -->
                        <div class="row">
                            <div class="col-12" style="text-align:center;">
                                <h4>WAREHOUSE MATERIAL</h4>
                            </div>
                        </div>
                        <div class="row" style="border-bottom:1px solid;">
                            <div class="col-12">
                                <table class="table table-bordered table-borderless">
                                    <tr style="font-weight:bold;">
                                        <td>SUPLIER :</td>
                                        <td rowspan="2"><span t-if="line.product_id.barcode" t-field="line.product_id.barcode" t-options="{'widget': 'barcode','symbology':'QR', 'width': 75, 'height': 75, 'img_align': 'center'}"/></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <span t-field="o.partner_id.name"/><br/>
                                            <span t-field="o.partner_id.street"/><br/>
                                            <span t-field="o.partner_id.street2"/>
                                            <t t-if="o.partner_id.city">
                                                , <span t-field="o.partner_id.city"/>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- package detail -->
                        <div class="row">
                            <div class="col-12" style="text-align:center;">
                                <h5>PACKAGE DETAILS</h5>
                            </div>
                        </div>
                        <div class="row" style="border-bottom:1px solid;">
                            <div class="col-12">
                                <table class="table table-bordered table-borderless">
                                    <tr>
                                        <td style="padding:0px; padding-left:8px; padding-top:7px;">ITEM NO : </td>
                                        <td style="padding:0px; padding-left:8px; padding-top:7px;"><span t-field="line.product_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px;">QUANTITY : </td>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px;"><span t-field="line.qty_done"/> <span t-field="line.product_uom_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px;">PURCHASE ORDER : </td>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px;"><span t-field="line.move_id.purchase_line_id.order_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px;">UOM : </td>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px;"><span t-field="line.product_uom_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px; padding-bottom:7px;">LOT NO : </td>
                                        <td style="padding:0px; padding-left:8px; padding-top:4px; padding-bottom:7px;"><span t-field="line.lot_name"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Material Description -->
                        <div class="row">
                            <div class="col-12" style="padding:4px; text-align:center;">
                                MATERIAL DESCRIPTION
                            </div>
                        </div>
                        <div class="row" style="padding:4px; border-bottom:1px solid;">
                            <div class="col-12" style="font-weight: bold; font-size:25px; text-align:center;">
                                <span t-field="line.move_id.purchase_line_id.order_id.name"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <table class="table table-bordered table-borderless">
                                    <tr>
                                        <td style="border-right: 1px solid; vertical-align:middle;" rowspan="2"><span t-if="line.result_package_id.name" t-field="line.result_package_id.name" t-options="{'widget': 'barcode', 'width': 210, 'height': 40}"/></td>
                                        <td style="border-bottom: 1px solid;">PACKAGE ID: <br/>
                                            <span t-field="line.result_package_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>PACKAGE NUMBER: <br/>
                                            <span t-esc="line_index + 1"/> <span>OF</span> <span t-esc="len(o.move_line_ids_without_package)"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- computer date and time -->
                        <div class="row" style="padding:4px; border-top:1px solid; text-align:center;">
                            <div class="col-12">
                                COMPUTER DATE AND TIME
                            </div>
                        </div>
                        <div class="row" style="padding:4px; text-align:center;">
                            <div class="col-12">
                                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d.%m.%Y @ %H:%M')"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
