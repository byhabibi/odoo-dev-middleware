                            </tr>
                            <tr>
                                <td><b>For</b></td>
                                <td>:</td>
                                <td><t t-if="o.partner_id.company_type != 'company'"><span t-field="o.partner_id.parent_id"/></t><t t-else=""><span t-field="o.partner_id"/></t></td>
                            </tr>
                            <tr>
                                <td><b>Attn</b></td>
                                <td>:</td>
                                <td><t t-if="o.partner_id.company_type != 'company'"><span t-field="o.partner_id.name"/></t></td>
                            </tr>
                        </table>
                        <br/>
                        Berikut Kami Kirimkan INVOICE Sebagai Berikut:
                        <br/>
                        <table class="" style="width:100%;">
                            <thead>
                                <tr>
                                    <td class="text-center">NO. INVOICE</td>
                                    <td class="text-center">NO. FAKTUR PAJAK</td>
                                    <td class="text-center">AMOUNT</td>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center"><span t-field="o.name"/></td>
                                    <td class="text-center"><span t-field="o.l10n_id_tax_number"/></td>
                                    <td style="text-align:right !important;"><span t-field="o.amount_total"/></td>
                                </tr>
                                <tr>
                                    <td colspan="2"></td>
                                    <td style="text-align:right !important;"><span t-field="o.amount_total"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <br/>
                        <table class="" style="width:100%;">
                            <thead>
                                <tr>
                                    <td class="text-center" style="width:180px;">PENGIRIM</td>
                                    <td style="border-top:hidden;border-bottom:hidden;"></td>
                                    <td class="text-center" style="width:180px;">PENERIMA</td>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="height:75px;"></td>
                                    <td style="height:75px;border-top:hidden;border-bottom:hidden;"></td>
                                    <td style="height:75px;"></td>
                                </tr>
                            </tbody>
                            <tfoot>
