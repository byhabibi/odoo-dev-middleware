        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eran_custom.eran_template_report_tanda_terima_faktur_bill</field>
        <field name="report_file">eran_custom.eran_template_report_tanda_terima_faktur_bill</field>
        <field name="print_report_name">'Tanda Terima Faktur %s' % object.name</field>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eran_paperformat_report_tanda_terima_faktur"/>
    </record>

    <record id="eran_action_report_tanda_terima_faktur_invoice" model="ir.actions.report">
        <field name="name">Tanda Terima Faktur Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eran_custom.eran_template_report_tanda_terima_faktur_invoice</field>
        <field name="report_file">eran_custom.eran_template_report_tanda_terima_faktur_invoice</field>
        <field name="print_report_name">'Tanda Terima Faktur %s' % object.name</field>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eran_paperformat_report_tanda_terima_faktur"/>
    </record>

    <template id="eran_template_report_tanda_terima_faktur_bill">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
