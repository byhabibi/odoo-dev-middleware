<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="eran_paperformat_report_purchase_order" model="report.paperformat">
        <field name="name">Purchase Order Paperformat</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="eran_action_report_purchase_order" model="ir.actions.report">
        <field name="name">Purchase Order</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eran_custom.eran_template_report_purchase_order</field>
        <field name="report_file">eran_custom.eran_template_report_purchase_order</field>
        <field name="print_report_name">'Purchase Order - %s' % object.name</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eran_paperformat_report_purchase_order"/>
    </record>

    <record id="eran_action_report_purchase_order_konversi" model="ir.actions.report">
        <field name="name">Purchase Order Konversi</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eran_custom.eran_template_report_purchase_order_konversi</field>
        <field name="report_file">eran_custom.eran_template_report_purchase_order_konversi</field>
        <field name="print_report_name">'Purchase Order Konversi- %s' % object.name</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eran_paperformat_report_purchase_order"/>
    </record>

    <record id="purchase.action_report_purchase_order" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
    </record>

    <template id="eran_template_report_purchase_order">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                    <style type="text/css">
                        *,
                        p,
                        span,
                        table,
                        table th,
                        table td{
                            font-size:14px;
                        }
                        .fs-12,
                        .fs-12 *,
                        .fs-12 p,
                        .fs-12 span,
                        .fs-12 table th,
                        .fs-12 table td
                        {
                            font-size:12px !important;
                        }
                        table,
                        table th,
                        table td{
                            border : 1px solid black;
                        }
                        table th,
                        table td{
                            padding: 2px 5px;
                        }
                        table.borderless,
                        table.borderless tr,
                        table.borderless th,
                        table.borderless td{
                            border : transparent;
                        }
                        .print-friendly *
                        {
                            page-break-inside: avoid;
                        }
                    </style>
                    <div class="row mb-3">
                        <div style="position:relative;width:55%;border:1px solid black;">
                            <center><b><u><span style="font-size:20px;">PURCHASE ORDER</span></u></b></center>
                            <center><b><span style="font-size:20px;">No: </span><span style="font-size:20px;" t-field="o.name"/></b></center>
                            <table style="width:100%;" class="borderless">
                                <tr>
                                    <td style="width:100px;">Vendor No.</td>
                                    <td style="width:10px;">:</td>
                                    <td><b><!--<span t-field="o.partner_id.eran_code"/>--></b></td>
                                </tr>
                                <tr>
                                    <td style="width:100px;">Vendor Name</td>
                                    <td style="width:10px;">:</td>
                                    <td><b><span t-field="o.partner_id"/></b></td>
                                </tr>
                                <t t-if="o.partner_id.child_ids.filtered(lambda x:x.type == 'contact')" t-set="vendor_attn" t-value="o.partner_id.child_ids.filtered(lambda x:x.type == 'contact')[0]"/>
                                <tr>
                                    <td style="width:100px;">Attn</td>
                                    <td style="width:10px;">:</td>
                                    <td><b><!--<span t-if="vendor_attn" t-esc="vendor_attn.name"/>--></b></td>
                                </tr>
                                <tr>
                                    <td colspan="3">Address:</td>
                                </tr>
                                <tr>
                                    <td colspan="3">
                                        <span t-field="o.partner_id.street"/> <span t-field="o.partner_id.street2"/> <span t-field="o.partner_id.city"/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div style="position:relative;width:45%;border:1px solid black;padding: 0px 5px;" class="fs-12">
                            <img t-att-src="image_data_uri(o.company_id.logo)" style="max-width:300px;width:100%;" alt="Logo"/>
                            <br/>
                            <span t-field="o.company_id.street"/> <span t-field="o.company_id.street2"/>, <span t-field="o.company_id.city"/>, <span t-field="o.company_id.state_id"/>
                            <br/>
                            TELP <span t-field="o.company_id.phone"/>, FAX <span t-field="o.company_id.eran_fax"/>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <table class="mt-3" style="width:100%;border:transparent; table-layout: fixed;">
                                <t t-set="nomor" t-value="1"/>
                                <tr>
                                    <td style="text-align:center;width:4%;"><b>No.</b></td>
                                    <td style="text-align:center;width:50%;"><b>Part</b></td>
                                    <td style="text-align:center;width:10%;"><b>Qty</b></td>
                                    <td style="text-align:center;width:18%;"><b>Harga</b></td>
                                    <td style="text-align:center;width:18%;"><b>Amount</b></td>
                                </tr>
                                <t t-set="down_payment" t-value="o.get_down_payment()"/>
                                <t t-set="disc_amount" t-value="0"/>
                                <t t-set="total_amount" t-value="0"/>
                                <t t-set="disc_persent" t-value="0"/>
                                <t t-foreach="o.order_line.filtered(lambda o: o.product_id.id != down_payment)" t-as="line">
                                    <t t-set="disc_amount" t-value="disc_amount + ((line.product_qty * line.price_unit) * (line.discount/100))"/>
                                    <t t-set="total_amount" t-value="total_amount + line.product_qty * line.price_unit"/>
                                    <t t-if="line.discount != 0">
                                        <t t-set="disc_persent" t-value="line.discount"/>
                                    </t>
                                    <t t-if="'[' in line.name and ']' in line.name">
                                        <t t-set="start" t-value="line.name.index('[')"/>
                                        <t t-set="end" t-value="line.name.index(']')+1"/>
                                        <t t-set="part_name" t-value="line.name.replace(line.name[start:end],'').strip()"/>
                                    </t>
                                    <t t-else="">
                                        <t t-set="part_name" t-value="line.name"/>
                                    </t>
                                    <tr t-if="not line.display_type">
                                        <t t-set="harga" t-value="line.product_qty * line.price_unit"/>
                                        <td style="border-top:0px transparent;border-bottom:0px transparent;width:10px;"><span t-esc="nomor"/></td>
                                        <td style="border-top:0px transparent;border-bottom:0px transparent;"><span t-esc="part_name"/></td>
                                        <td style="border-top:0px transparent;border-bottom:0px transparent;text-align:right;"><span t-esc="line.product_qty" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/> <span t-field="line.product_uom"/></td>
                                        <td style="border-top:0px transparent;border-bottom:0px transparent;text-align:right;"><span t-field="line.price_unit" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></td>
                                        <td style="border-top:0px transparent;border-bottom:0px transparent;text-align:right;"><span t-esc="harga" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></td>
                                        <t t-set="nomor" t-value="nomor+1"/>
                                    </tr>
                                    <!-- <tr t-else="">
                                        <td colspan="5">
                                            <span t-field="line.name"/>
                                        </td>
                                    </tr> -->
                                </t>

                                <t t-if="total_amount != 0">
                                    <t t-set="disc_percent" t-value="int(disc_persent)"/>
                                </t>
                                <t t-else="">
                                    <t t-set="disc_percent" t-value="0"/>
                                </t>

                                <tr t-if="len(o.order_line.filtered(lambda o: o.product_id.id != down_payment)) &lt; 33" t-foreach="range(33-len(o.order_line))" t-as="line_filler">
                                    <td style="border-top:0px transparent;border-bottom:0px transparent;width:10px;">&amp;nbsp;</td>
                                    <td style="border-top:0px transparent;border-bottom:0px transparent;">&amp;nbsp;</td>
                                    <td style="border-top:0px transparent;border-bottom:0px transparent;">&amp;nbsp;</td>
                                    <td style="border-top:0px transparent;border-bottom:0px transparent;">&amp;nbsp;</td>
                                    <td style="border-top:0px transparent;border-bottom:0px transparent;">&amp;nbsp;</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div class="row" style="margin-right:0px; border-top:1px solid black;">
                        <div style="clear: both;">
                            <div style="float: left; width: 64%; border-right:0px;">
                                Note:<br/>
                                <span t-field="o.notes"/>
                                Delivery : <span t-field="o.date_planned" t-options="{'widget': 'datetime', 'format': 'dd/MM/yyyy HH:mm'}"/><br/>
                                Delivery To : <span t-field="o.company_id"/><br/>
                                <span t-field="o.company_id.street"/> <span t-field="o.company_id.street2"/>, <span t-field="o.company_id.city"/>, <span t-field="o.company_id.state_id"/>
                            </div>
                            <div style="float: right; width: 36%;">
                                <table style="width:100%;border:transparent; table-layout: fixed;">
                                    <tr>
                                        <td style="border:1px solid black; border-top:0; width:50%;">Total</td>
                                        <td style="border:1px solid black; border-top:0;text-align:right;width:50%;"><span t-esc="total_amount" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid black; border-top:0;">DPP</td>
                                        <td style="border:1px solid black; border-top:0;text-align:right;"><span t-esc="o.dpp" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid black; border-top:0;">Disc <span t-esc="disc_percent"/>%</td>
                                        <td style="border:1px solid black; border-top:0;text-align:right;"><span t-esc="disc_amount" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></td>
                                    </tr>
                                    <tr t-foreach="o.tax_totals['groups_by_subtotal']['Untaxed Amount']" t-as="group">
                                        <td style="border:1px solid black; border-top:0;"><span t-esc="group['tax_group_name']"/></td>
                                        <td style="border:1px solid black; border-top:0;text-align:right;"><span t-esc="group['tax_group_amount']" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></td>
                                    </tr>
                                    <tr>
                                        <t t-set="disc_amount" t-value="0"/>
                                        <t t-set="tax_totals" t-value="0"/>
                                        <t t-foreach="o.order_line" t-as="line">
                                            <t t-set="disc_amount" t-value="disc_amount + ((line.product_qty * line.price_unit) * (line.discount/100))"/>
                                        </t>
                                        <t t-foreach="o.tax_totals['groups_by_subtotal']['Untaxed Amount']" t-as="group">
                                            <t t-set="tax_totals" t-value="tax_totals + group['tax_group_amount']"/>
                                        </t>
                                        <t t-set="nett_amount" t-value="o.tax_totals['amount_total'] - disc_amount + tax_totals"/>
                                        <td style="border:1px solid black;">Nett</td>
                                        <td style="border:1px solid black;text-align:right;"><span t-esc="o.tax_totals['amount_total']" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3 print-friendly" style="padding-left:50px;">
                        <div class="col-8">
                            <t t-set="today_date" t-value="datetime.datetime.now().strftime('%d %b %Y')"/>
                            <span>Jakarta,</span> <span t-esc="o.date_order.strftime('%d %B %Y')"/><br/>
                            <t t-set="signatures" t-value="o.get_signatures()"/>
                            <table style="width:100%; background-image: url('/eran_custom/static/src/img/stample_purchase.png'); background-position: 50px 0px; background-repeat: no-repeat;">
                                <tr>
                                    <td style="width:120px;text-align:center;">Issued By,</td>
                                    <td style="width:120px;text-align:center;">Approved By,</td>
                                    <td style="width:240px;text-align:center;" colspan="2">Release By,</td>
                                </tr>
                                <tr>
                                    <t t-set="sign_ids" t-value="o.env['hr.employee'].sudo().search([('user_id', '=', o.create_uid.id)])"/>
                                    <!-- <td style="height:100px;width:100px; vertical-align: middle;">
                                        <t t-if="len(sign_ids) &gt; 0 and sign_ids.signature != False and o.approval_line_ids[0].is_approved == True">
                                            <img t-att-src="image_data_uri(sign_ids.signature)" style="max-width:120px;width:100%;" alt="Signature"/>
                                        </t>
                                    </td> -->
                                    <td style="height:100px;width:100px; vertical-align: middle;">
                                        <t t-if="len(sign_ids) &gt; 0 and len(o.approval_line_ids) &gt; 0 ">
                                          <t t-if="sign_ids.signature != False ">
                                            <img t-att-src="image_data_uri(sign_ids.signature)" style="max-width:120px;width:100%;" alt="Signature"/>
                                          </t>
                                        </t>
                                    </td>
                                    <td style="height:100px;width:100px; vertical-align: middle;">
                                        <t t-if="len(o.approval_line_ids) &gt; 0 and o.approval_line_ids[0].signature != False and o.approval_line_ids[0].is_approved == True">
                                            <img t-att-src="image_data_uri(o.approval_line_ids[0].signature)" style="max-width:120px;width:100%;" alt="Signature"/>
                                        </t>
                                    </td>
                                    <td style="height:80px;width:120px; vertical-align: middle;">
                                        <t t-if="len(o.approval_line_ids) &gt; 1 and o.approval_line_ids[1].signature != False and o.approval_line_ids[1].is_approved == True">
                                            <img t-att-src="image_data_uri(o.approval_line_ids[1].signature)" style="max-width:120px;width:100%;" alt="Signature"/>
                                        </t>
                                    </td>
                                    <td style="height:80px;width:120px; vertical-align: middle;">
                                        <t t-if="len(o.approval_line_ids) &gt; 2 and o.approval_line_ids[2].signature != False and o.approval_line_ids[2].is_approved == True"> 
                                            <img t-att-src="image_data_uri(o.approval_line_ids[2].signature)" style="max-width:120px;width:100%;" alt="Signature"/>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                      <t t-set="sign_ids" t-value="o.env['hr.employee'].sudo().search([('user_id', '=', 55)])"/>
                                    <td style="text-align:center; height:20px;">
                                        <t t-if="len(sign_ids) &gt; 0">
                                            <span t-esc="sign_ids.user_id.name" style="font-size:12px;"/>
                                        </t>
                                    </td>
                                    <td style="text-align:center; height:20px;">
                                        <t t-if="len(o.approval_line_ids) &gt; 0 and o.approval_line_ids[0].user_id != False">
                                            <span t-esc="o.approval_line_ids[0].user_id.name" style="font-size:12px;"/>
                                        </t>
                                    </td>
                                    <td style="text-align:center; height:20px;">
                                        <t t-if="len(o.approval_line_ids) &gt; 1 and o.approval_line_ids[1].user_id != False">
                                            <span t-esc="o.approval_line_ids[1].user_id.name" style="font-size:12px;"/>
                                        </t>
                                    </td>
                                    <td style="text-align:center; height:20px;">
                                        <t t-if="len(o.approval_line_ids) &gt; 2 and o.approval_line_ids[2].user_id != False">
                                            <span t-esc="o.approval_line_ids[2].user_id.name" style="font-size:12px;"/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-4" style="padding-left: 40px; padding-top: 5px;">
                            <br/>
                            <table style="width:100%;">
                                <tr>
                                    <td style="text-align:center;">Confirmation</td>
                                </tr>
                                <tr>
                                    <td style="height:100px;"/>
                                </tr>
                                <tr>
                                    <td style="text-align:center; height:20px;"><span t-field="o.partner_id" style="font-size:12px;"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <template id="eran_template_report_purchase_order_konversi">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                    <style type="text/css">
                        *,
                        p,
                        span,
                        table,
                        table th,
                        table td{
                            font-size:14px;
                        }
