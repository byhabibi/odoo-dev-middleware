    <record id="eran_data_entry_sto_line_form_view" model="ir.ui.view">
        <field name="name">eran.data.entry.sto.line.form</field>
        <field name="model">eran.stock.move.opname.line</field>
        <field name="arch" type="xml">
            <form string="Data Entry STO Line">
                <sheet>
                    <group>
                        <group>
                            <field name="product_id" readonly="1"/>
                            <field name="stock_opname_id" readonly="1"/>
                            <field name="locations" readonly="1"/>
                            <field name="quantity_done_kg" readonly="1"/>
                            <field name="product_uom" readonly="1"/>
                            <field name="is_weight" readonly="1"/>
                            <field name="no_tag" readonly="1"/>
                            <field name="state" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="stock_opname_line_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id" readonly="1"/>
                            <field name="lot_id" readonly="1"/>
                            <field name="quantity_done" readonly="1"/>
                            <field name="tracing" readonly="1"/>
                            <field name="count_date" readonly="1"/>
                            <field name="tag_sto_id" readonly="1"/>
                            <field name="value" readonly="1"/>
                            <field name="categ_id" readonly="1"/>
                            <field name="category_group_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="eran_data_entry_sto_line_search_view" model="ir.ui.view">
        <field name="name">eran.data.entry.sto.line.search</field>
        <field name="model">eran.stock.move.opname.line</field>
        <field name="arch" type="xml">
            <search>
                <group expand="0" string="Group By">
                    <filter string="Product" name="groupby_product_id" domain="[]" context="{'group_by': 'product_id'}"/>
                    <filter string="Product Category" name="groupby_categ_id" domain="[]" context="{'group_by': 'categ_id'}"/>
                    <filter string="Category Group" name="groupby_category_group_id" domain="[]" context="{'group_by': 'category_group_id'}"/>
                    <filter string="State" name="groupby_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Tag STO" name="groupby_tag_sto_id" domain="[]" context="{'group_by': 'tag_sto_id'}"/>
                </group>
            </search>
        </field>
    </record>

