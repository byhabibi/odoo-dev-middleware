<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="eran_sale_order_inherit_form_view" model="ir.ui.view">
        <field name="name">sale.order.view.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- <xpath expr="//field[@name='pricelist_id']" position="after">
                <field name="expiration_date"/>
            </xpath> -->
            <xpath expr="//button[@name='action_draft']" position="attributes">
                <attribute name="string">Reset to Draft</attribute>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="order_date" invisible="1"/>
                <field name="po_ref" attrs="{'readonly': [('state', 'in', ('sale', 'done', 'cancel'))]}"/>
                <field name="start_date" attrs="{'readonly': [('state', 'in', ('sale', 'done', 'cancel'))]}"/>
                <field name="check_osheet_so" invisible="1"/>
                <!-- <field name="qty_os" invisible="1"/> -->
            </xpath>
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,sale</attribute>
            </xpath>
            <xpath expr="//div/button[@name='action_view_invoice']" position="before">
                <button type="object"
                    name="action_view_delivery_order_on_picking"
                    class="oe_stat_button"
                    icon="fa-truck" attrs="{'invisible':[('picking_count_delivery','=', 0)]}">
                    <field name="picking_count_delivery" widget="statinfo" string="Delivery"/>
                </button>
            </xpath>
            <xpath expr="//div/button[@name='action_view_invoice']" position="after">
                <button type="object"
                    name="action_view_order_sheet"
                    class="oe_stat_button"
                    icon="fa-pencil-square-o" attrs="{'invisible':[('order_sheet_count','=', 0)]}">
                    <field name="order_sheet_count" widget="statinfo" string="Order Sheet"/>
                </button>
            </xpath>
            <xpath expr="//notebook/page[@name='order_lines']/group/group[2]/field[@name='tax_totals']" position="before">
                <button colspan="2" name="compute_global_discount" string="Discount" type="object" class="oe_right btn-secondary" attrs="{'invisible':['|','|', ('order_sheet_count','>', 0), ('picking_count_delivery','>',0), ('invoice_count','>',0)]}" />
            </xpath>
            <xpath expr="//page[@name='order_lines']/field[@name='order_line']/tree/field[@name='product_uom_qty']" position="after">
                <field name="order_sheet_line_qty" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']" position="after">
                <field name="product_code" optional="show"/>
                <field name="product_name" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='qty_delivered']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='qty_delivered']" position="after">
                <field name="quantity_delivery" />
            </xpath>

            <xpath expr="//page/group[@name='note_group']/group/field[@name='tax_totals']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page/group[@name='note_group']/group/field[@name='tax_totals']" position="after">
                <field name="amount_untaxed" />
                <field name="dpp"  widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="amount_tax" />
                <field name="amount_total" class="oe_subtotal_footer_separator"/>
            </xpath>
        </field>
    </record>
    
    <record id="eran_view_order_form_inherit_sale_stock_inherit" model="ir.ui.view">
        <field name="name">eran.view.order.form.inherit.sale.stock.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_delivery']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale.action_orders" model="ir.actions.act_window">
        <field name="domain">[('state', 'not in', ('sent', 'cancel'))]</field>
