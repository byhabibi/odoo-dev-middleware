    <record id="eran_sales_perfomance_view_tree" model="ir.ui.view">
        <field name="name">eran.forecast.line.view.tree</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <tree string="Sales Perfomance" create="false" edit="false" delete="false">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="price_so"/>
                <field name="date_so"/>
                <field name="qty_so"/>
                <field name="price_subtotal_so"/>
                <field name="date_os" widget="date"/>
                <field name="qty_os"/>
                <field name="price_subtotal_os"/>
                <field name="date_picking_id"/>
                <field name="quantity_done"/>
                <field name="price_subtotal_picking"/>
            </tree>
        </field>
    </record>

    <record id="eran_sales_perfomance_action" model="ir.actions.act_window">
        <field name="name">Sales Perfomance</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">tree,pivot</field>
        <field name="domain">[('picking_type_id', '=', 2)]</field>
        <field name="context">{}</field>
        <field name="view_id" ref="eran_sales_perfomance_view_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new order sheet
            </p>
        </field>
    </record>
    <record id="eran_sales_order_line_view_tree" model="ir.ui.view">
