    <record id="eran_production_performance_report_action" model="ir.actions.act_window">
        <field name="name">Production Performance Report</field>
        <field name="res_model">eran.production.performance.report</field>
        <field name="type">ir.actions.act_window</field>
        <!-- <field name="view_id" ref="eran_production_performance_report_tree_view"/> -->
        <field name="view_mode">tree,graph,pivot</field>
        <field name="search_view_id" ref="eran_production_performance_report_search"/>
        <!-- ✅ CONTEXT BARU DITAMBAH -->
        <field name="context">{'search_default_default_filter_this_month': 1}</field>
        <!-- ✅ LIMIT BARU DITAMBAH -->
        <field name="limit">80</field>
    </record>
