<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="mrp_workcenter_productivity_tree_view" model="ir.ui.view">
        <field name="name">mrp.workcenter.productivity.tree.view</field>
        <field name="model">mrp.workcenter.productivity.loss</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name" />
                <field name="loss_type" />
                <field name="loss_id" />
            </tree>
        </field>
    </record>

    <record id="action_mrp_workcenter_productivity" model="ir.actions.act_window">
        <field name="name">Workcenter Activity Loss</field>
        <field name="res_model">mrp.workcenter.productivity.loss</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="mrp_workcenter_productivity_tree_view" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new
            </p>
        </field>
    </record>
</odoo>