<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_no_good_view_tree" model="ir.ui.view">
        <field name="name">eran.no.good.view.tree</field>
        <field name="model">eran.no.good</field>
        <field name="arch" type="xml">
            <tree string="No Good" editable="bottom">
                <field name="name"/>
                <field name="standard"/>
                <field name="ng_group"/>
            </tree>
        </field>
    </record>

    <record id="eran_no_good_action" model="ir.actions.act_window">
        <field name="name">Jenis NG</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">eran.no.good</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new No Good
            </p>
        </field>
    </record>

</odoo>