<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="eran_stock_opname_view_form" model="ir.ui.view">
        <field name="name">eran.stock.opname.view.form</field>
        <field name="model">eran.stock.opname</field>
        <field name="arch" type="xml">
            <form string="Stock_Opname">
                <header>
                    <button name="action_button_confirm" string="Confirm" type="object" class="btn-primary" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <!-- <button name="action_button_cancel" string="Cancel" type="object" attrs="{'invisible': [('state', 'in', ('cancel', 'confirm', 'done'))]}"/> -->
                    <button name="action_button_reset_to_draft" string="Reset to Draft" type="object" class="btn-primary" attrs="{'invisible': [('state', '!=', 'confirm')]}"/>
                    <field name="state" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="no_tag" readonly="1"/>
                        </h1>
                    </div>
                    <group name="stock_opname_group">
                        <group name="left_group">
                            <field name="tag_sto_id" domain="[('state','=','confirmed')]"/>
                            <field name="locations" required="1" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="count_date" readonly="1"/>
                            <field name="note"/>
                        </group>
                        <group name="right_group">
                            <field name="counter_id" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="checker" readonly="1"/>
                            <field name="data_entry" readonly="1"/>
                            <field name="invoice_control" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="operations" string="Operations" invisible="1">
                            <field name="sto_line_ids" attrs="{'readonly': [('state', '!=', 'draft')]}">
                                <tree name="stock_opname_line" editable="bottom">
                                    <field name="product_id" required="1"/>
                                    <!-- <field name="counted"/> -->
                                    <field name="quantity_done"/>
                                    <field name="quantity_done_kg"/>
                                    <field name="product_uom" readonly="1"/>
                                    <field name="notes"/>
                                    <button name="action_show_details" type="object" icon="fa-list" width="0.1" title="Details"/>
                                </tree>
                            </field>
                        </page>
                        <page name="detail_operations" string="Detailed Operations">
                            <field name="stock_move_opname_line_ids" attrs="{'readonly': [('state', '!=', 'draft')]}">
                                <tree name="stock_opname_line" editable="bottom">
                                    <field name="locations" optional="hide"/>
                                    <field name="product_id" options="{'no_create_edit': True, 'no_quick_create':True, 'no_create': True}"/>
                                    <field name="lot_id"/>
                                    <field name="quantity_done"/>
                                    <field name="quantity_done_kg"/>
                                    <field name="product_uom" readonly="1"/>
                                    <field name="is_weight" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="eran_stock_opname_line_view_operations" model="ir.ui.view">
        <field name="name">eran_stock_opname_line_view_operations_form</field>
        <field name="model">eran.stock.opname.line</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <form string="Move Detail">
                <group>
                    <group>
                        <field name="stock_opname_id" invisible="1"/>
                        <field name="locations" invisible="1"/>
                        <field name="company_id" invisible="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="tracing" invisible="1"/>
                        <label for="quantity_done"/>
                        <div class="o_row">
                            <span><field name="quantity_done" readonly="1" nolabel="1"/></span>
                            <span><field name="product_uom" readonly="1" nolabel="1"/></span>
                            <!-- <span> / </span>
                            <span><field name="counted" nolabel="1" readonly="1" /></span> -->
                        </div>
                    </group>
                </group>
                <field name="stock_move_opname_line_ids" context="{'tree_view_ref': 'eran_custom.eran_stock_move_opname_line_view_tree', 'default_product_uom': product_uom, 'default_stock_opname_id': stock_opname_id, 'default_stock_opname_line_id': id, 'default_product_id': product_id, 'default_locations': locations, 'default_company_id': company_id, 'default_tracing': tracing}"/>
                <footer class="oe_edit_only">
                    <button string="Confirm" special="save" data-hotkey="v" class="oe_highlight"/>
                    <button string="Cancel" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="eran_stock_opname_view_tree" model="ir.ui.view">
        <field name="name">eran.stock.opname.view.tree</field>
        <field name="model">eran.stock.opname</field>
        <field name="arch" type="xml">
            <tree string="Stock Opname">
                <field name="no_tag"/>
                <field name="locations" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                <field name="tag_sto_id" />
                <field name="internal_reference"/>
                <field name="product_names" />
                <field name="count_date" readonly="1"/>
                <field name="counted_qty" />
                <field name="product_uom" />
                <field name="state" string="Status"/>
            </tree>
        </field>
    </record>

    <record id="eran_stock_opname_view_search" model="ir.ui.view">
        <field name="name">eran_stock_opname_view_search</field>
        <field name="model">eran.stock.opname</field>
        <field name="arch" type="xml">
            <search string="search master drawing">
                <field name="no_tag"/>
                <field name="tag_sto_id" />
                <field name="product_names" />
                <field name="locations" />
            </search>
        </field>
    </record>

    <record id="eran_stock_opname_action" model="ir.actions.act_window">
        <field name="name">Data Entry STO</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">eran.stock.opname</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="eran_stock_opname_view_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Stock Opname
            </p>
        </field>
    </record>

    <record id="eran_stock_move_opname_line_view_tree" model="ir.ui.view">
        <field name="name">eran.stock.move.opname.line.view.tree</field>
        <field name="model">eran.stock.move.opname.line</field>
        <field name="arch" type="xml">
            <tree string="Stock Move Opname Line" editable="bottom">
                <field name="product_id" invisible="1"/>
                <field name="stock_opname_id" invisible="1"/>
                <field name="locations" force_save="1"/>
                <field name="lot_id" attrs="{'readonly': [('tracing', '=', 'none')], 'required': [('tracing', 'in', ('lot', 'serial'))]}"/>
                 <field name="is_weight" invisible="1"/>
                <field name="quantity_done" attrs="{'readonly': ['|',('tracing', '=', 'serial'), ('is_weight', '=', True)]}" force_save="1"/>
                <field name="quantity_done_kg" attrs="{'readonly': [('is_weight', '=', False)]}"/>
                <field name="product_uom"/>
                <field name="tracing" invisible="1"/>
            </tree>
        </field>
    </record>
    
</odoo>
