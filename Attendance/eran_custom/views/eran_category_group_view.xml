<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_category_group_view_tree" model="ir.ui.view">
        <field name="name">eran.category.group.view.tree</field>
        <field name="model">eran.category.group</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="eran_category_group_view_form" model="ir.ui.view">
        <field name="name">eran.category.group.view.form</field>
        <field name="model">eran.category.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">Category Group</span>
                        <h1 class="d-flex">
                            <field name="name" force_save="1"/>
                        </h1>
                    </div>
                    
                </sheet>
            </form>
        </field>
    </record>

    <record id="eran_category_group_action" model="ir.actions.act_window">
        <field name="name">Category Group</field>
        <field name="res_model">eran.category.group</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>
