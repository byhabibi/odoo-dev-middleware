        <field name="arch" type="xml">
            <pivot string="Stock Moves Analysis" sample="1">
                <field name="product_id" type="row"/>
                <field name="location_dest_id" type="row"/>
                <field name="quantity_done" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_return_order_line_search" model="ir.ui.view">
        <field name="name">view.return.order.line.search</field>
        <field name="model">eran.return.order.line</field>
        <field name="arch" type="xml">
            <search string="Stock Moves">
                <field name="picking_id" string="Transfer" filter_domain="[('picking_id', 'ilike', self)]"/>
                <field name="partner_id" string="Contact" filter_domain="[('partner_id', 'ilike', self)]"/>
                <field name="product_id" string="Product" filter_domain="[('product_id', 'ilike', self)]"/>
                <field name="location_id" string="Source Location"/>
                <field name="location_dest_id" string="Destination Location"/>
                <separator/>
                <filter string="Effective Date" name="today" date="date_done_picking"/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="by_product" domain="[]"  context="{'group_by': 'product_id'}"/>
                    <filter string="Category Group" name="category_group" domain="[]" context="{'group_by':'category_group_id'}"/>
                    <filter string="Transfer" name="groupby_picking_id" domain="[]"  context="{'group_by': 'picking_id'}"/>
                    <filter string="Source Location" name="groupby_location_id" domain="[]" context="{'group_by': 'location_id'}"/>
                    <filter string="Destination Location" name="groupby_dest_location_id" domain="[]" context="{'group_by': 'location_dest_id'}"/>
                    <filter string="Effective Date" name="groupby_date" domain="[]" context="{'group_by': 'date_done_picking'}"/>
                </group>
            </search>
        </field>
    </record>

