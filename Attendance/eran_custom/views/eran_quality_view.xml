    <record id="eran_lembar_masalah_kualitas_view_form" model="ir.ui.view">
        <field name="name">eran.lembar.masalah.kualitas.view_form</field>
        <field name="model">eran.lembar.masalah.kualitas</field>
        <field name="arch" type="xml">
            <form string="Lembar Masalah Kerja">
            <header>
                <field name="state" widget="statusbar" statusbar_visible="draft,waiting_approval,done"/>
                <button name="btn_waiting_approval" string="Request Approval" type="object" class="btn btn-primary" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                <button name="btn_approved" string="Approve" type="object" class="btn btn-primary" attrs="{'invisible': ['|', ('user_in_assigned_to', '=', False),('state', '!=', 'waiting_approval')]}"/>
                <button name="btn_set_to_draft" string="Set To Draft" type="object" class="btn btn-primary" attrs="{'invisible': [('state', 'in', ('draft','closed'))]}"/>
                <button name="btn_create_pica" string="Create Pica" type="object" class="btn btn-primary" attrs="{'invisible': ['|', ('is_pica_created', '=', True),('state', '!=', 'done')]}"/>
                <!-- <button name="btn_create_pica" string="Create Pica" type="object" class="btn btn-primary"/> -->
            </header>
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_pica"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o"
                            attrs="{'invisible': [('pica_count', '=', 0)]}">
                        <field name="pica_count" widget="statinfo" string="PICA"/>
                    </button>
                </div>
                <div class="oe_title">
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                </div>
                <group name="sheet_header">
                    <group name="partner_details">
                        <field name="is_pica_created" invisible="1"/>
                        <field name="quality_check_id" invisible="1"/>
                        <field name="partner_type" required="1" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}" />
                        <field name="lmk_type" required="1" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="lmk_date" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="delivery_date" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="production_date" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="product_id" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="order_sheet_id" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="order_qty" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="part_defect_type_ids" widget="many2many_tags" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="area_found_ids" widget="many2many_tags" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                    </group>
                    <group name="sheet_details">
                        <field name="picking_id" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="production_id" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="point_id" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="team_id" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="partner_id" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="tindakan_sementara" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="batas_waktu" attrs="{'readonly': [('state', 'in', ['done', 'waiting_approval'])]}"/>
                        <field name="company_id" invisible="1"/>
                    </group>
                </group>
                <notebook>
                    <page string="LMK Details" name="lmk_lines">
                        <field name="lmk_line_ids" attrs="{'readonly': [('state', '!=', 'draft')]}">
                            <tree string="LMK Details" editable="bottom">
                                <field name="quantity_sample"/>
                                <field name="not_good_id"/>
                                <field name="quantity_ng"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Attachment" name="lmk_attachment">
                        <field name="lmk_attachment_ids" attrs="{'readonly': [('state', '!=', 'draft')]}">
                            <tree string="Attachment" editable="bottom">
                                <field name="image" required="1" widget="image" options="{'size': [300, 300]}"/>
                            </tree>
                        </field>
                    </page>
                    <!-- APPROVAL -->
                    <page name="approver" string="Approver">
                        <group>
                            <group>
                                <field name="user_in_assigned_to" invisible="1"/>
                                <field name="approval_qc_id"/>
                                <field name="approval_rule"/>
                                <field name="approval_type"/>
                            </group>
                            <group>
                                <field name="approve_uid"/>
                                <field name="approve_date"/>
                            </group>
                        </group>
                        <field name="approval_line_ids" mode="tree" readonly="1">
                            <tree string="Approval Line" name="approval_line" editable="bottom">
                                <field name="user_id"/>
                                <field name="is_approved"/>
                                <field name="date_approved"/>
                            </tree>
                        </field>
                    </page>
                    <!-- END APPROVAL -->
                </notebook>
            </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids"/>
                <field name="activity_ids"/>
                <field name="message_ids"/>
            </div>
            </form>
        </field>
    </record>

    <!-- KANBAN Lembar Masalah Kualitas -->
    <record id="eran_lembar_masalah_kualitas_kanban_view" model="ir.ui.view">
        <field name="name">eran.lembar.masalah.kualitas</field>
        <field name="model">eran.lembar.masalah.kualitas</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="name"/>
                <field name="lmk_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="row mb4">
                                <strong class="col-12">
                                    <span t-esc="record.partner_id.value"/>
                                </strong>
                            </div>
                            <div class="row mb4">
                                <div class="col-12">
                                    <span t-esc="record.product_id.value"/>
                                </div>
                            </div>
                            <div class="row mb4">
                                <div class="col-6">
                                    <span t-esc="record.name.value"/>
                                </div>
                                <div class="col-3">
                                    <span t-esc="record.lmk_date.value"/>
                                </div>
                                <div class="col-3">
                                    <span t-attf-class="badge #{ ['draft', 'waiting_approval', 'done'].includes(record.state.raw_value) ? 'bg-200' : 'bg-info' }">
                                        <t t-esc="record.state.raw_value"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!--  -->

    <record id="eran_lembar_masalah_kualitas_view_search" model="ir.ui.view">
        <field name="name">eran.lembar.masalah.kualitas.view.search</field>
