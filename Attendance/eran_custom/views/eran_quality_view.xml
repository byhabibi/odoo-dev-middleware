<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_view_quality_check_wizard_inherit" model="ir.ui.view">
        <field name="name">eran.quality_check_wizard.view.inherit</field>
        <field name="model">quality.check.wizard</field>
        <field name="inherit_id" ref="quality_control.view_quality_check_wizard"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='do_pass'][2]" position="attributes">
                <attribute name="string">Validate</attribute>
            </xpath>
            <xpath expr="//button[@name='do_fail']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='do_pass'][2]" position="after">
                <button name="create_lmk" type="object" string="Create LMK" class="btn btn-primary"/>
            </xpath>
            <xpath expr="//field[@name='additional_note']" position="after">
                <field name="order_sheet_id"/>
                <field name="order_qty" force_save="1"/>
                <field name="good_qty"/>
                <field name="not_good_qty"/>
            </xpath>
            <xpath expr="//footer" position="after">
                <notebook>
                    <page string="Not Good" name="sheet_lines">
                        <field name="quality_ng_ids">
                            <tree string="Not Good" editable="bottom">
                                <field name="not_good_id" options="{'no_open':True,'no_create': True}"/>
                                <field name="ng_qty"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Attachment" name="attachment_qc_lines">
                        <field name="quality_attachment_ng_ids">
                            <tree string="Attachment" editable="bottom">
                                <field name="image" required="1" widget="image" options="{'size': [300, 300]}"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>

    <record id="eran_quality_check_view_form_inherit" model="ir.ui.view">
        <field name="name">eran.quality.check.view.inherit</field>
        <field name="model">quality.check</field>
        <field name="inherit_id" ref="quality_control.quality_check_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='do_pass'][1]" position="attributes">
                <attribute name="string">Validate</attribute>
            </xpath>
            <xpath expr="//header/button[@name='do_pass'][2]" position="attributes">
                <attribute name="string">Validate</attribute>
            </xpath>
            <xpath expr="//header/button[@name='do_fail'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='do_fail'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_see_alerts']" position="after">
                <button name="action_lmk_list" icon="fa-file-text" type="object" class="oe_stat_button" attrs="{'invisible': [('lmk_count', '=', 0)]}">
                    <field name="lmk_count" string="LMK" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//header/button[@name='do_alert']" position="after">
                <button name="do_set_draft" type="object" attrs="{'invisible': ['|', ('alert_ids', '!=', []), ('quality_state', '=', 'none')]}" string="Set TO DO"/>
                <button name="create_lmk" type="object" class="btn btn-primary" attrs="{'invisible': [('lmk_count', '!=', 0)]}" string="Create LMK"/>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="order_sheet_id"/>
                <field name="order_qty" force_save="1"/>
                <field name="good_qty"/>
                <field name="not_good_qty"/>
                <field name="lmk_ids" invisible="1"/>
            </xpath>
            <xpath expr="//group/group/field[@name='picking_id']" position="after">
                <field name="batch_id" readonly="1"/>
            </xpath>
            <xpath expr="//page[@name='notes']" position="after">
                <page string="Not Good" name="sheet_lines">
                    <field name="quality_ng_ids" attrs="{'readonly': [('quality_state', '!=', 'none')]}">
                        <tree string="Not Good" editable="bottom">
                            <field name="not_good_id" options="{'no_open':True,'no_create': True}"/>
                            <field name="ng_qty"/>
                        </tree>
                    </field>
                </page>
                <page string="Attachment" name="attachment_qc_lines">
                    <field name="quality_attachment_ng_ids" attrs="{'readonly': [('quality_state', '!=', 'none')]}">
                        <tree string="Attachment" editable="bottom">
                            <field name="image" required="1" widget="image" options="{'size': [300, 300]}"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="eran_quality_check_view_tree_inherit" model="ir.ui.view">
