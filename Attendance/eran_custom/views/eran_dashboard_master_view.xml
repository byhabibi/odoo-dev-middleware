    <record id="eran_master_loss_opportunity_view_tree" model="ir.ui.view">
        <field name="name">eran.master.loss.opportunity.view.tree</field>
        <field name="model">master.loss.opportunity</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="date" />
                <field name="currency_id" invisible="1"/>
                <field name="category_group_id" />
                <field name="target" />
                <field name="problem" />
                <field name="activity" />
            </tree>
        </field>
    </record>

