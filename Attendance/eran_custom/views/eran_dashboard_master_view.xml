        <field name="name">Loss Opportunity</field>
        <field name="res_model">master.loss.opportunity</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="eran_master_loss_opportunity_view_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new
            </p>
        </field>
    </record>

