        <field name="inherit_id" ref="stock.stock_scrap_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="product_category_group_id"/>
            </xpath>
        </field>
    </record> -->
</odoo>
