<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_cost_vendor_pricelist_view_tree" model="ir.ui.view">
        <field name="name">eran.cost.vendor.pricelist.view.tree</field>
        <field name="model">eran.cost.vendor.pricelist</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <!-- <field name="partner_id"/> -->
                <field name="start_date"/>
                <field name="end_date"/>
            </tree>
        </field>
    </record>

    <record id="eran_cost_vendor_pricelist_view_form" model="ir.ui.view">
        <field name="name">eran.cost.vendor.pricelist.view.form</field>
        <field name="model">eran.cost.vendor.pricelist</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Confirm" name="action_confirm" type="object" class="oe_highlight" states="draft"/>
                    <button string="Compute" name="action_compute" type="object" class="oe_highlight" states="draft"/>
                    <button string="Reset to Draft" name="action_reset" type="object" states="confirm"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">Cost Vendor Pricelist</span>
                        <h1 class="d-flex">
                            <field name="name" readonly="1" force_save="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="start_date" required="1" attrs="{'readonly':[('state','!=','draft')]}"/>
                            <field name="end_date" required="1" attrs="{'readonly':[('state','!=','draft')]}"/>
                            <!-- <field name="partner_id" required="1" attrs="{'readonly':[('state','!=','draft')]}"/> -->
                        </group>
                    </group>
                    <notebook>
                        <page name="avg_pricelist_page" string="Average Vendor Pricelist">
                            <field name="pricelist_line_ids" readonly="1" force_save="1">
                                <tree>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="avg_price"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="eran_cost_vendor_pricelist_action" model="ir.actions.act_window">
        <field name="name">Cost Vendor Pricelist</field>
        <field name="res_model">eran.cost.vendor.pricelist</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>
