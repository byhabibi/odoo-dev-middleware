    <!-- ================ ERAN QUOTATION & LOI APPROVAL MENUITEM ================ -->
    <!-- This code more than your fokin tought about -->
    
    <!-- Action Window To Approve -->
    <record id="action_dsn_to_approve_quotation" model="ir.actions.act_window">
      <field name="name">Quotation</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">eran.quotation</field>
      <field name="domain">[('state', '=', 'to_approve')]</field>
      <field name="view_mode">tree,form</field>
      <field name="context">{'search_default_assigned_to_ids': 1, 'create':False, 'delete':False}</field>
      <field name="search_view_id" ref="eran_custom.eran_quotation_view_search"/>
    </record>
    <!-- Action Window To Approve -->
    <record id="action_dsn_to_approve_loi" model="ir.actions.act_window">
      <field name="name">LOI</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">eran.quotation.loi</field>
      <field name="domain">[('state', '=', 'to_approve')]</field>
      <field name="view_mode">tree,form</field>
      <field name="context">{'search_default_assigned_to_ids': 1, 'create':False, 'delete':False}</field>
      <field name="search_view_id" ref="eran_custom.eran_loi_view_search"/>
    </record>
    <!-- Action Window To Approve -->
    <record id="action_dsn_to_approve_stock" model="ir.actions.act_window">
      <field name="name">Stock</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">stock.picking</field>
      <field name="domain">[('state_approval', '=', 'to_approve')]</field>
      <field name="view_mode">tree,form</field>
      <field name="context">{'search_default_assigned_to_ids': 1, 'create':False, 'delete':False}</field>
      <field name="search_view_id" ref="eran_custom.eran_stock_view_search"/>
    </record>
