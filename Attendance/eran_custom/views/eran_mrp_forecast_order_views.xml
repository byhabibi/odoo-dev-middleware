    <record id="eran_inherit_dsn_view_mps_tree" model="ir.ui.view">
        <field name="name">eran.inherit.dsn.view.mps.tree</field>
        <field name="model">dsn.mps</field>
        <field name="inherit_id" ref="mrp_forecast_order.dsn_view_mps_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='scheduled_date']" position="after">
                <field name="level" invisible="1"/>
                <field name="shift_id" readonly="1"/>
                <field name="leader_id" readonly="1"/>
                <field name="operator_id" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="default_code" readonly="1"/>
                <field name="part_name" readonly="1"/>
            </xpath>
        </field>
    </record>
    
    <record model="ir.actions.act_window" id="mrp_forecast_order.dsn_action_mps">
        <field name="name">MPS</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">dsn.mps</field>
        <field name="domain">[]</field>
        <field name="context">{'create': 0, 'copy': 0, 'delete':0, 'search_default_type_order': 1, 'search_default_demand_order': 1}</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="mrp_forecast_order.dsn_view_mps_filter"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to start a new demand order for demand order detail process and generate mps from demand order detail.
            </p>
            <p>
                MPS of semi-finished and finished goods.
            </p>
        </field>
    </record>

