            <xpath expr="//field[@name='product_id']" position="after">
                <field name="default_code" readonly="1"/>
                <field name="part_name" readonly="1"/>
                <field name="categ_group_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="mrp_forecast_order.dsn_view_mrp_filter" model="ir.ui.view">
        <field name="name">dsn.view.mrp.filter</field>
        <field name="model">dsn.mrp</field>
        <field name="arch" type="xml">
            <search string="Search MPS">
