    <record model="ir.actions.act_window" id="mrp_forecast_order.dsn_action_mrp">
        <field name="name">MRP</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">dsn.mrp</field>
        <field name="domain">[]</field>
        <field name="context">{'create': 0, 'copy': 0, 'delete':0, 'search_default_type_order': 1, 'search_default_demand_order': 1}</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="mrp_forecast_order.dsn_view_mrp_filter"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to start a new demand order for demand order detail process and generate mrp from demand order.
            </p>
            <p>
                MRP of material.
            </p>
        </field>
