<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FIX ORDER-->
    <record model="ir.actions.act_window" id="dsn_action_sale_forecast_fix_order">
        <field name="name">Fix Order</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">dsn.forecast.order</field>
        <field name="domain">[('type', '=', 'fix_order')]</field>
        <field name="context">{'default_type': 'fix_order'}</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to start a new fix order process.
            </p>
            <p>
                Fix orders plan the production finished goods.
            </p>
        </field>
    </record>


    <!--DEMAND-->
    <record id="eran_view_demand_order_form_inherit" model="ir.ui.view">
        <field name="name">eran.view.demand.order.form.inherit</field>
        <field name="model">dsn.demand.planning</field>
        <field name="inherit_id" ref="mrp_forecast_order.dsn_view_demand_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//group/field[@name='company_id']" position="before">
                <label for="percen_forecast" attrs="{'invisible':  [('type', '!=', 'fix_order')]}"/>
                <div name="percen_div" class="d-flex" attrs="{'invisible':  [('type', '!=', 'fix_order')]}">
                    <field name="percen_forecast" class="oe_inline"/>
                    <span class="oe_inline o_form_label mx-3"> % </span>
                </div>
            </xpath>
            <xpath expr="//button[@name='set_mrp']" position="after">
                <button name="action_report_mrp_xlsx" string="Print MRP" type="object"/>
                <!-- <button name="%(eran_action_report_cover_letter_attachment)d" string="Print CLA" type="action" attrs="{'invisible':  [('type', '!=', 'fix_order')]}"/> -->
                <button name="action_print_report_cla" string="Print CLA" type="object" attrs="{'invisible':  [('type', '!=', 'fix_order')]}"/>
            </xpath>
            <xpath expr="//label[@for='start_date']" position="before">
                <field name="type" required="1" attrs="{'readonly': [('state', '!=', 'draft')]}"></field>
            </xpath>
            <xpath expr="//field[@name='line_ids']/tree/field[@name='deadline_date']" position="attributes">
                <attribute name="required">0</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']/tree/field[@name='product_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']/tree/field[@name='product_id']" position="after">
                <field name="default_code" readonly="1"/>
                <field name="part_name" readonly="1"/>
            </xpath>
            <xpath expr="//button[@name='set_mrp']" position="after">
                <button name="set_mrp_non_material" string="Set MRP Non Material" type="object" class="oe_highlight" 
                   attrs="{'invisible':['|',('state', '=', 'draft'),('overhead_ids', '!=', [])]}" confirm="Are you sure about the quantity that will be produced?"/>
                <button name="set_demand_forecast" string="Set Forecast" type="object" class="oe_highlight" attrs="{'invisible':['|',('state', '=', 'draft'),('demand_order_forecast_count', '!=', 0)]}" confirm="Are you sure?"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Work Center Overhead Detail" attrs="{'invisible':[('overhead_ids', '=', [])]}">
                    <field name="overhead_ids" readonly="1">
                        <tree editable="bottom">
                            <field name="product_id" options="{'no_open':True,'no_create': True}" required="1" 
                                domain="[('detailed_type', '=', 'product')]" readonly="1"/>
                            <field name="bom_id" readonly="1"/>
                            <field name="demand_workcenter_id" />
                            <field name="qty" readonly="1"/>
                            <field name="uom_id" options="{'no_open':True,'no_create': True}" required="1" force_save="1" readonly="1"/>
                        </tree>
                    </field>
                </page>
            </xpath>
            <xpath expr="//button[@name='view_mrp']" position="after">
                <button class="oe_stat_button" name="view_demand_order_forecast" type="object" icon="fa-book"
                    attrs="{'invisible':[('demand_order_forecast_count','=',0)]}">
                    <field string="Forecast" name="demand_order_forecast_count" widget="statinfo"/>
                </button>
                <button class="oe_stat_button" name="view_mrp_non_material" type="object" icon="fa-pencil"
                    attrs="{'invisible':[('mrp_non_material_count','=',0)]}">
                    <field string="MRP Non Material" name="mrp_non_material_count" widget="statinfo"/>
                </button>
                 <button class="oe_stat_button" name="view_deman_order_detail" type="object" icon="fa-pencil"
                    attrs="{'invisible':[('state','=','draft')]}">
                    <field string="Demand Order Detail" name="demand_order_detail_count" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//group//group" position="inside">
                <label for="forecast_start_date" string="Forecast Range"/>
                <div>
                    <field name="forecast_start_date"  class="oe_inline"
                        attrs="{'readonly': [('demand_order_forecast_count', '!=', 0)]}"/> - <field name="forecast_end_date" class="oe_inline" attrs="{'readonly': [('demand_order_forecast_count', '!=', 0)]}"/>
                </div>
                <field name="deadline_date" required="1" attrs="{'readonly': [('state', '!=', 'draft')]}"></field>
                <field name="forecast_ids" invisible="1"></field>
            </xpath>
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="confirm">Bill of Material in demand detail cannot be empty. Are you sure want to continue?</attribute>
            </xpath>
        </field>
    </record>

    <record id="eran_view_demand_order_filter" model="ir.ui.view">
        <field name="name">eran.view.demand.order.filter</field>
        <field name="model">dsn.demand.planning</field>
        <field name="arch" type="xml">
            <search string="Search Demand Order">
                <field name="name" string="Document Number" filter_domain="[('name', 'ilike', self)]"/>
                <group expand="0" string="Group By...">
                    <filter string="Type" name="type_order" domain="[]" context="{'group_by': 'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="mrp_forecast_order.dsn_action_demand_order">
        <field name="name">Demand Order</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">dsn.demand.planning</field>
        <field name="context">{}</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_type_order': 1}</field>
        <field name="search_view_id" ref="eran_view_demand_order_filter"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to start a new demand order process.
            </p>
            <p>
                Demand orders plan the production of semi-finished and finished goods and make purchases for materials.
            </p>
        </field>
    </record>

    <!--DEMAND LINE-->
    <record id="mrp_forecast_order.dsn_view_demand_order_detail_filter" model="ir.ui.view">
        <field name="name">dsn.view.demand.order.detail.filter</field>
        <field name="model">dsn.demand.planning.line</field>
        <field name="arch" type="xml">
            <search string="Search Demand Order Detail">
                <field name="demand_id" string="Demand Order" filter_domain="[('demand_id', 'ilike', self)]"/>
                <field name="product_id" string="Product" filter_domain="[('product_id', 'ilike', self)]"/>
                <group expand="0" string="Group By...">
                    <filter string="Type" name="type_order" domain="[]" context="{'group_by': 'type'}"/>
                    <filter string="Demand Order" name="demand_order" domain="[]" context="{'group_by': 'demand_id'}"/>
                    <filter string="Deadline Date" name="deadline_date" domain="[]" context="{'group_by': 'deadline_date'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <record id="eran_inherit_dsn_view_demand_order_detail_tree" model="ir.ui.view">
        <field name="name">eran.inherit.dsn.view.demand.order.detail.tree</field>
        <field name="model">dsn.demand.planning.line</field>
        <field name="inherit_id" ref="mrp_forecast_order.dsn_view_demand_order_detail_tree" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='generate_mps']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='level']" position="before">
                <header>
                     <button name="generate_multi_mps" string="Generate MPS" type="object"/>
                </header>
                <field name="id" string="ID"/>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="default_code" readonly="1"/>
                <field name="part_name" readonly="1"/>
            </xpath>
        </field>
    </record>
    
    <record model="ir.actions.act_window" id="mrp_forecast_order.dsn_action_demand_order_detail">
        <field name="name">Demand Order Detail</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">dsn.demand.planning.line</field>
        <field name="domain">[('demand_id.state', '!=', 'draft'), ('production_qty', '!=', 0), ('bom_type', '=', 'normal')]</field>
        <field name="context">{'create': 0, 'copy': 0, 'delete':0, 'search_default_type_order': 1, 'search_default_demand_order': 1}</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="mrp_forecast_order.dsn_view_demand_order_detail_filter"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to start a new demand order for demand order detail process.
            </p>
            <p>
                Demand orders detail plan the production of semi-finished and finished goods.
            </p>
        </field>
    </record>

