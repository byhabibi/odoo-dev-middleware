<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="eran_inventory_setting_sequences_view_form" model="ir.ui.view">
        <field name="name">eran.inventory.setting.sequences.view.form</field>
        <field name="model">dsn.inventory.sequence.setting</field>
        <field name="inherit_id" ref="dsn_sequence_setting.dsn_inventory_setting_sequences_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//group/group/field[@name='type']" position="after">
                <field name="name_operations" attrs="{'invisible': [('type', '!=', 'transfer')]}"/>
                <field name="type_operations" attrs="{'invisible': [('type', '!=', 'transfer')]}"/>
            </xpath>
        </field>
    </record>

</odoo>
