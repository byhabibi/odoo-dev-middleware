<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="eran_kpi_vendor_report_search" model="ir.ui.view">
        <field name="name">eran.kpi.vendor.report.search</field>
        <field name="model">eran.kpi.vendor.report</field>
        <field name="arch" type="xml">
            <search string="Search KPI Vendor Report">
                <field name="partner_id"/>
                <field name="purchase_id"/>
                <field name="product_id"/>
            </search>
        </field>
    </record>

    <record id="eran_kpi_vendor_report_tree_view" model="ir.ui.view">
        <field name="name">eran.kpi.vendor.report.tree.view</field>
        <field name="model">eran.kpi.vendor.report</field>
        <field name="arch" type="xml">
            <tree string="KPI Vendor Report" create="false" delete="false">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="price_unit"/>
                <field name="purchase_id"/>
                <field name="order_date"/>
                <field name="order_qty"/>
                <field name="sub_total"/>
                <field name="order_sheet_id" invisible="1"/>
                <field name="order_sheet_date" widget="date"/>
                <field name="order_sheet_qty"/>
                <field name="sub_total_order_sheet"/>
                <field name="picking_id" invisible="1"/>
                <field name="receipt_date"/>
                <field name="receipt_qty"/>
                <field name="sub_total_receipt"/>
                <field name="state_picking" widget="badge" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="eran_kpi_vendor_report_pivot_view" model="ir.ui.view">
        <field name="name">eran.kpi.vendor.report.pivot_view</field>
        <field name="model">eran.kpi.vendor.report</field>
        <field name="arch" type="xml">
            <pivot string="KPI Vendor Report">
                <field name="product_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="eran_kpi_vendor_report_action" model="ir.actions.act_window">
        <field name="name">KPI Vendor Report</field>
        <field name="res_model">eran.kpi.vendor.report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_id" ref="eran_kpi_vendor_report_tree_view"/>
        <field name="view_mode">tree,graph,pivot</field>
        <field name="search_view_id" ref="eran_kpi_vendor_report_search"/>
    </record>
</odoo>
