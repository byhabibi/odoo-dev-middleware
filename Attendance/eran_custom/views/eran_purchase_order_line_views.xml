<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- reporting -->
    <record id="purchase_order_line_reporting_tree_view" model="ir.ui.view">
        <field name="name">purchase.order.line.reporting.tree.tree</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <tree string="Purchase Order Line" create="0" edit="0" delete="0">
                <header>
                    <button string="Recompute Received Amount" name="call_compute_received_amt" type="object" class="oe_highlight"/>
                </header>
                <field name="po_number" optional="show"/>
                <field name="origin" optional="show"/>
                <field name="purchase_request_id" optional="show"/>
                <field name="request_date" optional="show"/>
                <field name="purchase_type" optional="show"/>
                <field name="date_order" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="internal_transfer" optional="show"/>
                <field name="product_name" optional="show"/>
                <field name="name" optional="show"/>
                <field name="product_qty" optional="show"/>
                <field name="additional_qty" string="Quantity Convert" optional="show"/>
                <field name="resuply_qty" optional="show"/>
                <field name="balance_qty_subcont" optional="show"/>
                <field name="qty_received" optional="show"/>
                <field name="received_convert" optional="show"/>
                <field name="total_qty_recv" optional="hide"/>
                <field name="balance_qty" string="Amount Balance Qty" optional="show"/>
                <field name="total_balance_qty" optional="show"/>
                <field name="total_balance_qty_convert" optional="show"/>
                <field name="received_amt" optional="show"/>
                <field name="receipt_status" optional="show"/>
                <field name="price_unit" optional="show"/>
                <field name="taxes_id" optional="show"/>
                <field name="price_subtotal" optional="show"/>
                <field name="propagate_cancel" optional="show"/>
                <field name="confirmation_date" optional="show"/>
                <field name="category_ids" optional="show" widget="many2many_tags"/>
                <field name="date_planned" optional="show"/>
                <field name="state" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="purchase_order_line_search_inherit" model="ir.ui.view">
        <field name="name">purchase.order.line.view.search.inherit</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='groupby_product']" position="after">
                <filter string="Category Group" name="category_group" domain="[]" context="{'group_by':'category_group_id'}"/>
                <filter string="Date Order" name="by_date_order" domain="[]" context="{'group_by':'date_order'}"/>
            </xpath>
        </field>
    </record>

    <record id="action_purchase_order_line_report_all" model="ir.actions.act_window">
        <field name="name">Purchase Order Line</field>
        <field name="res_model">purchase.order.line</field>
        <field name="view_mode">tree,pivot</field>
        <field name="view_id" ref="purchase_order_line_reporting_tree_view"/>
    </record>

    <menuitem id="purchase.purchase_order_line_report" 
        name="Purchase Order Line" 
        parent="purchase.purchase_report_main" 
        sequence="1" 
        groups="purchase.group_purchase_manager" 
        action="action_purchase_order_line_report_all"/>

</odoo>
